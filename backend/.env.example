# --- Required ---
# Pooled Postgres URL (Neon, Supabase, Railway Postgres, etc.)
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# Public URL(s) of your Vite frontend, comma-separated (CORS + Socket.IO).
# Example: https://smash-precision.vercel.app
# Multiple: https://app.example.com,https://preview-xxx.vercel.app
FRONTEND_URL=http://localhost:3000

# --- Secrets (set in host dashboard, never commit) ---
# Cloudinary (product image uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Horizontal scaling (optional for single instance) ---
# Redis URL for Socket.IO adapter (same pub/sub across API replicas).
# Upstash / Redis Cloud / Railway Redis — use rediss:// for TLS.
# Leave unset for local single-process dev (in-memory Socket.IO only).
# REDIS_URL=redis://localhost:6379

# --- Server ---
# PORT=3001
