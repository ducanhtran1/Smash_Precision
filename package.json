{
  "name": "smash-precision",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "yarn workspace react-example dev",
    "dev:backend": "yarn workspace backend start:dev",
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\"",
    "lint": "yarn workspace backend lint && yarn workspace react-example lint",
    "lint:fix": "yarn workspace backend lint && yarn workspace backend format && yarn workspace react-example lint",
    "postinstall": "echo 'Monorepo setup complete.'"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
