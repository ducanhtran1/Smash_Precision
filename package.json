{
  "name": "smash-precision",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "yarn workspace react-example dev",
    "dev:backend": "yarn workspace backend start:dev",
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\"",
    "postinstall": "echo 'Monorepo setup complete.'"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
